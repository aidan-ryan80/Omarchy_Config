#!/bin/bash

STATUS_FILE="/sys/bus/platform/drivers/ideapad_acpi/VPC2004:00/conservation_mode"

if [[ ! -f "$STATUS_FILE" ]]; then
    echo "Error: Conservation mode file not found"
    exit 1
fi

# Determine what to do
case $1 in
    "full")
        NEW_MODE=0
        ;;
    "safe")
        NEW_MODE=1
        ;;
    *)
        # Default behavior: If no valid arg is given, just flip the current state
        CURRENT=$(cat "$STATUS_FILE")
        [ "$CURRENT" -eq 0 ] && NEW_MODE=1 || NEW_MODE=0
        ;;
esac

# Perform the action
echo "$NEW_MODE" | sudo tee "$STATUS_FILE" > /dev/null

# Terminal Output (For your eyes only)
if [ "$NEW_MODE" -eq 1 ]; then
    echo "Capping at 60% (Desk Mode)"
else
    echo "Charging to 100% (Travel Mode)"
fi
