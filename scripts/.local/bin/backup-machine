#!/bin/bash
set -e

export BORG_PASSCOMMAND='cat /root/.borg-passphrase'

HOSTNAME=$(hostname)

case "$HOSTNAME" in
    Acer-PHN16-omarchy)
        MIRROR_DIR="@mirror-acer"
        BORG_REPO="/mnt/backup/@borg"
        BORG_PREFIX="acer"
        ;;
    Ideapad-omarchy)
        MIRROR_DIR="@mirror-ideapad"
        BORG_REPO="/mnt/backup/@borg"
        BORG_PREFIX="ideapad"
        ;;
    *)
        echo "Unknown hostname: $HOSTNAME. Aborting."
        exit 1
        ;;
esac

print_storage_report() {
    echo "--- Storage Report: $1 ---"
    echo "Overall SSD Usage:"
    df -h /mnt/backup 2>/dev/null || echo "No backup data found."

    echo "--- Paths (Machine: $HOSTNAME) ---"
    echo "Mirror: /mnt/backup/$MIRROR_DIR"
    echo "Borg repo: $BORG_REPO"
    echo "Borg prefix: $BORG_PREFIX"
    sudo du -sh "/mnt/backup/$MIRROR_DIR" "$BORG_REPO" 2>/dev/null || echo "No backup data found."

    if [ -d "$BORG_REPO" ]; then
        echo "Borg Repository Details:"
        sudo BORG_PASSCOMMAND="$BORG_PASSCOMMAND" borg info "$BORG_REPO"
    fi
    echo "---------------------------------"
}

cleanup() {
    echo "Unmounting..."
    sudo umount /mnt/backup 2>/dev/null || true
}

trap cleanup EXIT

echo "--- Starting Backup: $(date) ---"
echo "Host: $HOSTNAME"

mkdir -p /mnt/backup
sudo mount -L BACKUPS /mnt/backup

print_storage_report "Pre-Backup"

echo "Running Rsync..."
sudo rsync -avAXH --delete \
    --exclude-from="/home/aidan/.config/rsync/exclude.txt" \
    /home/aidan/ "/mnt/backup/$MIRROR_DIR/"

echo "Running Borg..."
sudo BORG_PASSCOMMAND="$BORG_PASSCOMMAND" borg create --stats --compression zstd,3 \
    --exclude-from /home/aidan/.config/borg/borg_exclude.txt \
    "$BORG_REPO::${BORG_PREFIX}-home-{now:%Y-%m-%d_%H:%M}" \
    /home/aidan

print_storage_report "Post-Backup"

echo "Pruning old backups..."
sudo BORG_PASSCOMMAND="$BORG_PASSCOMMAND" borg prune -v --list "$BORG_REPO" \
    --glob-archives "${BORG_PREFIX}-*" \
    --keep-daily=7 \
    --keep-weekly=4 \
    --keep-monthly=6 \
    --keep-yearly=2

echo "Compacting repository..."
sudo BORG_PASSCOMMAND="$BORG_PASSCOMMAND" borg compact "$BORG_REPO"

echo "--- Backup Completed: $(date) ---"
