#!/bin/bash

 # Then create markdown with descriptions
 echo -e "| Package | Description |\n| :--- | :--- |" > packages.md
 while read -r pkg; do
     desc=$(pacman -Qiq "$pkg" | grep "^Description" | cut -d: -f2- | sed 's/^[ \t]*//')
     [ -n "$desc" ] && echo "| $pkg | $desc |" >> packages.md
 done < packages.txt
