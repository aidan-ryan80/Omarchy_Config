term = ghostty

# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "CaskaydiaMono Nerd Font"
font-style = Regular
font-size = 9

# Window
window-padding-x = 14
window-padding-y = 14
confirm-close-surface=false
resize-overlay = never

# Cursor styling
cursor-style = "block"
cursor-style-blink = false
shell-integration-features = no-cursor

# Keyboard bindings

keybind = f11=toggle_fullscreen
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# Not default for Omarchy or Ghostty:
keybind = ctrl+w=close_surface
keybind = ctrl+shift+h=new_split:left
keybind = ctrl+shift+numpad_page_up=move_tab:-1
keybind = ctrl+shift+numpad_page_down=move_tab:1
keybind = ctrl+shift+page_up=move_tab:-1
keybind = ctrl+shift+page_down=move_tab:1

# Rebinding keybindings that don't work on my laptop Keyboard
keybind = shift+numpad_home=scroll_to_top
keybind = shift+numpad_end=scroll_to_bottom
keybind = shift+numpad_page_up=scroll_page_up
keybind = shift+numpad_page_down=scroll_page_down

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
